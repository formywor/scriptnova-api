<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <title>ScriptNova — Browser Launcher</title>

  <hta:application
    applicationname="ScriptNova"
    id="app"
    border="thin"
    caption="yes"
    maximizebutton="no"
    minimizebutton="yes"
    sysmenu="yes"
    scroll="no"
    singleinstance="yes"
  />

  <style>
    html, body { height:100%; }
    body{
      margin:0;
      font-family:"Segoe UI", Tahoma, Arial;
      background:#0a0f17;
      color:#eaf2ff;
      overflow:hidden;
    }
    .wrap{
      height:100%;
      padding:14px;
      box-sizing:border-box;
      background:
        radial-gradient(circle at top left, rgba(0,229,255,.07), transparent 28%),
        radial-gradient(circle at top right, rgba(124,77,255,.06), transparent 24%),
        linear-gradient(180deg,#09101a 0%,#0b111b 100%);
    }

    .topbar{
      border:1px solid #22314a;
      border-radius:16px;
      padding:12px 14px;
      background:linear-gradient(180deg,#0f1724 0%, #0d1522 100%);
      box-shadow:0 0 20px rgba(0,229,255,0.07);
    }
    .brandRow{ display:table; width:100%; }
    .brandLeft,.brandRight{ display:table-cell; vertical-align:middle; }
    .brandLeft{ width:70%; }
    .brandRight{ width:30%; text-align:right; color:#9fb2d6; font-size:12px; }
    .logo{
      font-size:22px;
      font-weight:900;
      letter-spacing:.4px;
      color:#00e5ff;
      text-shadow:0 0 12px rgba(0,229,255,.16);
    }
    .subtitle{
      margin-top:4px;
      color:#9fb2d6;
      font-size:11px;
      letter-spacing:.2px;
    }

    .pill{
      display:inline-block;
      padding:6px 10px;
      border-radius:999px;
      background:#0e2a3a;
      border:1px solid rgba(0,229,255,0.35);
      color:#9fefff;
      font-size:12px;
      margin-top:6px;
    }
    .subpill{
      display:inline-block;
      padding:4px 8px;
      border-radius:999px;
      background:#0c1422;
      border:1px solid rgba(255,255,255,0.12);
      color:#9fb2d6;
      font-size:11px;
      margin-top:6px;
      margin-right:8px;
    }

    .layout{
      margin-top:12px;
      height:calc(100% - 88px);
      border:1px solid #22314a;
      border-radius:16px;
      background:linear-gradient(180deg,#0e1624 0%, #0b1220 100%);
      overflow:hidden;
      box-shadow:0 16px 34px rgba(0,0,0,.28);
    }

    .sidebar{
      float:left;
      width:270px;
      height:100%;
      border-right:1px solid #22314a;
      background:linear-gradient(180deg,#0b1320 0%, #0a111c 100%);
      overflow-y:auto;
    }
    .sideTitle{
      padding:12px;
      border-bottom:1px solid #22314a;
      color:#9fb2d6;
      font-size:12px;
      letter-spacing:.8px;
      text-transform:uppercase;
    }

    .tab{
      margin:10px;
      padding:10px;
      border:1px solid #22314a;
      border-radius:12px;
      background:#101a2b;
      color:#d8e6ff;
      font-weight:900;
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.02);
    }

    .sideCard{
      margin:10px;
      padding:12px;
      border:1px solid #22314a;
      border-radius:14px;
      background:linear-gradient(180deg,#0b1220 0%, #0a111c 100%);
      box-shadow:0 0 16px rgba(0,0,0,.15);
    }
    .sideCard h4{
      margin:0 0 8px 0;
      font-size:12px;
      letter-spacing:.8px;
      text-transform:uppercase;
      color:#9fb2d6;
    }
    .sideLine{
      font-size:12px;
      color:#d4e4ff;
      line-height:1.35;
      word-break:break-word;
    }
    .sideLabel{
      color:#8ea6ca;
      font-size:11px;
      margin-top:8px;
      text-transform:uppercase;
      letter-spacing:.5px;
    }

    .sideBtn{
      width:100%;
      padding:10px;
      margin-top:8px;
      border-radius:10px;
      border:1px solid rgba(0,229,255,0.45);
      background:linear-gradient(180deg,#103147 0%, #0e283b 100%);
      color:#eaf2ff;
      cursor:pointer;
      font-weight:900;
      letter-spacing:.7px;
      text-transform:uppercase;
      font-size:12px;
    }
    .sideBtn:hover{ background:linear-gradient(180deg,#143a54 0%, #113247 100%); }

    .main{
      margin-left:270px;
      height:100%;
      padding:12px;
      box-sizing:border-box;
      overflow-y:auto;
    }

    .card{
      border:1px solid #22314a;
      border-radius:16px;
      padding:14px;
      background:linear-gradient(180deg,#0c1421 0%, #0a111c 100%);
      margin-bottom:12px;
      box-shadow:0 0 18px rgba(0,0,0,.14);
    }
    .card h3{
      margin:0 0 8px 0;
      font-size:12px;
      letter-spacing:.8px;
      text-transform:uppercase;
      color:#9fb2d6;
    }

    .btn{
      width:100%;
      padding:12px;
      margin:8px 0;
      border-radius:12px;
      border:1px solid rgba(0,229,255,0.45);
      background:linear-gradient(180deg,#103147 0%, #0e283b 100%);
      color:#eaf2ff;
      cursor:pointer;
      font-weight:900;
      letter-spacing:.7px;
      text-transform:uppercase;
    }
    .btn:hover{ background:linear-gradient(180deg,#143a54 0%, #113247 100%); }

    .btn2{
      width:100%;
      padding:12px;
      margin:8px 0;
      border-radius:12px;
      border:1px solid rgba(124,77,255,0.45);
      background:linear-gradient(180deg,#24204f 0%, #1d1a42 100%);
      color:#eaf2ff;
      cursor:pointer;
      font-weight:900;
      letter-spacing:.7px;
      text-transform:uppercase;
    }
    .btn2:hover{ background:linear-gradient(180deg,#2a255d 0%, #221f4e 100%); }

    .btnWarn{
      width:100%;
      padding:12px;
      margin:8px 0;
      border-radius:12px;
      border:1px solid rgba(255,207,90,.45);
      background:linear-gradient(180deg,#4a3812 0%, #37290d 100%);
      color:#fff;
      cursor:pointer;
      font-weight:900;
      letter-spacing:.7px;
      text-transform:uppercase;
    }
    .btnWarn:hover{ background:linear-gradient(180deg,#58441a 0%, #443213 100%); }

    .btnDanger{
      width:100%;
      padding:12px;
      margin:8px 0;
      border-radius:12px;
      border:1px solid rgba(255,90,90,.45);
      background:linear-gradient(180deg,#4a1c20 0%, #371417 100%);
      color:#fff;
      cursor:pointer;
      font-weight:900;
      letter-spacing:.7px;
      text-transform:uppercase;
    }
    .btnDanger:hover{ background:linear-gradient(180deg,#5a2228 0%, #45191d 100%); }

    .btn:disabled, .btn2:disabled, .btnWarn:disabled, .btnDanger:disabled, .sideBtn:disabled{
      opacity:.55;
      cursor:not-allowed;
      filter:grayscale(35%);
    }

    .field{
      width:100%;
      padding:12px;
      border-radius:12px;
      border:1px solid #22314a;
      background:#070b12;
      color:#eaf2ff;
      outline:none;
      box-sizing:border-box;
      font-size:16px;
    }
    .field:focus{
      border-color:rgba(0,229,255,.42);
      box-shadow:0 0 0 3px rgba(0,229,255,.08);
    }

    .note{
      color:#9fb2d6;
      font-size:11px;
      line-height:1.4;
    }

    .banner{
      display:none;
      margin-bottom:12px;
      border-radius:16px;
      padding:13px 14px;
      border:1px solid rgba(0,229,255,0.35);
      background:linear-gradient(180deg,#0d2234 0%, #0d1d2f 100%);
      color:#eaf7ff;
      box-shadow:0 0 18px rgba(0,229,255,.05);
    }
    .banner.warn{
      border-color:rgba(255,207,90,.35);
      background:linear-gradient(180deg,#2c2512 0%, #251f10 100%);
      color:#fff0c5;
    }
    .banner.danger{
      border-color:rgba(255,90,90,.35);
      background:linear-gradient(180deg,#2f171b 0%, #261316 100%);
      color:#ffd9df;
    }
    .banner.success{
      border-color:rgba(40,220,130,.35);
      background:linear-gradient(180deg,#142b1e 0%, #112319 100%);
      color:#dbffea;
    }
    .banner .title{
      font-weight:900;
      margin-bottom:6px;
      letter-spacing:.2px;
    }
    .banner .actions{ margin-top:10px; }

    .miniBtn{
      display:inline-block;
      padding:8px 10px;
      margin-right:8px;
      margin-top:6px;
      border-radius:10px;
      border:1px solid rgba(255,255,255,.12);
      background:#13253d;
      color:#fff;
      cursor:pointer;
      font-weight:800;
      font-size:12px;
    }
    .miniBtn:hover{ background:#183050; }

    .pollOption{
      display:block;
      width:100%;
      text-align:left;
      margin-top:8px;
      padding:11px;
      border:1px solid #22314a;
      border-radius:12px;
      background:#101a2b;
      color:#eaf2ff;
      cursor:pointer;
      font-weight:700;
    }
    .pollOption:hover{ background:#16253d; }
    .pollMeta{ font-size:12px; color:#9fb2d6; margin-top:8px; }

    .listBox{
      border:1px solid #22314a;
      border-radius:12px;
      background:#09111d;
      padding:10px;
      max-height:220px;
      overflow:auto;
      font-family:Consolas, monospace;
      font-size:12px;
      color:#d7e8ff;
    }

    .statusGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }
    .tiny{
      padding:10px;
      border:1px solid #22314a;
      border-radius:12px;
      background:#09111d;
    }
    .tiny .k{
      color:#8ea6ca;
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.6px;
    }
    .tiny .v{
      color:#fff;
      font-size:13px;
      margin-top:6px;
      word-break:break-word;
    }

    .overlay{
      display:none;
      position:fixed;
      left:0; top:0; right:0; bottom:0;
      background:rgba(0,0,0,.72);
      z-index:9999;
    }
    .modal{
      width:650px;
      max-width:calc(100% - 40px);
      margin:68px auto 0 auto;
      border:1px solid #22314a;
      border-radius:20px;
      background:linear-gradient(180deg,#101927 0%, #0c1421 100%);
      box-shadow:0 0 34px rgba(0,0,0,.48);
      padding:18px;
    }
    .modal h2{
      margin:0 0 8px 0;
      color:#00e5ff;
      font-size:21px;
    }
    .modal .body{
      color:#dbe8ff;
      line-height:1.45;
      white-space:pre-wrap;
      font-size:14px;
    }
    .modal .btnRow{
      margin-top:14px;
      text-align:right;
    }
    .modal .btnRow button{
      width:auto;
      min-width:140px;
      display:inline-block;
      margin-left:8px;
    }

    .liveDot{
      display:inline-block;
      width:8px;
      height:8px;
      border-radius:999px;
      background:#29e38a;
      box-shadow:0 0 12px rgba(41,227,138,.75);
      margin-right:6px;
      vertical-align:middle;
    }

    .compactNote{
      margin-top:6px;
      font-size:10px;
      color:#88a1c9;
      letter-spacing:.25px;
    }
  </style>

  <script language="JScript">
(function(){
  function T(s){ return String(s||"").replace(/^\s+|\s+$/g,""); }
  function A(v){ return String(v||"").split(",").join(""); }
  function B(s){ try{ return window.atob(String(s||"")); }catch(e){ return ""; } }
  function D(parts){ return B(A(parts)); }
  function EH(s){
    s = String(s == null ? "" : s);
    return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }
  function EJ(s){
    s = String(s||"");
    return s.replace(/\\/g,"\\\\").replace(/'/g,"\\'").replace(/\r/g,"").replace(/\n/g,"");
  }
  function NS(){ return Math.floor((new Date().getTime())/1000); }

  function J(x){
    try{ return JSON.stringify(x); }catch(e){ return ""; }
  }

  function Hx(s){
    s = String(s||"");
    var h = 0, i = 0;
    for(i=0;i<s.length;i++){
      h = ((h << 5) - h) + s.charCodeAt(i);
      h = h & h;
    }
    return String(h);
  }

  function sameData(a,b){
    return Hx(J(a)) === Hx(J(b));
  }

  function alOff(){ alert("API offline"); }
  function alBad(){ alert("ScriptNova is a private tool and can only be used by some people if you are invited congrats if your not we dont care you can try to apply by emailing gomegaassist@gmail.com and we will probably respond in 15 days"); }
  function alApi(m){ alert("API error: " + String(m||"unknown")); }
  function alLim(){ alert("Too many people using the same key"); }
  function alLn(){ alert("Launcher error"); }
  function alUp(u){ alert("Please update to the latest file at " + String(u||"https://scriptnovaa.com/download")); }

  window.onerror = function(){ try{ alLn(); }catch(e){} return true; };

  var sh = new ActiveXObject("WScript.Shell");
  var fs = new ActiveXObject("Scripting.FileSystemObject");

  var R = {
    base: D(["aHR0","cHM6","Ly9h","cGku","c2Ny","aXB0","bm92","YWEu","Y29t"]),
    boot: "/" + D(["YXBp"]) + "/" + D(["Ym9v","dHN0","cmFw"]),
    epCheck: "/" + D(["YXBp"]) + "/" + D(["Y2hl","Y2s="]),
    epVerify: "/" + D(["YXBp"]) + "/" + D(["dmVy","aWZ5"]),
    epUi: "/" + D(["YXBp"]) + "/" + D(["dWk="]),
    epLaunch: "/" + D(["YXBp"]) + "/" + D(["bGF1","bmNo"]),
    epPing: "/" + D(["YXBp"]) + "/" + D(["cGlu","Zw=="]),
    epEnd: "/" + D(["YXBp"]) + "/" + D(["ZW5k"])
  };

  var Q = {
    cpu: D(["U0VM","RUNU","IFBy","b2Nl","c3Nv","cklk","IEZS","T00g","V2lu","MzJf","UHJv","Y2Vz","c29y"]),
    bios: D(["U0VM","RUNU","IFNl","cmlh","bE51","bWJl","ciBG","Uk9N","IFdp","bjMy","X0JJ","T1M="]),
    brd: D(["U0VM","RUNU","IFNl","cmlh","bE51","bWJl","ciBG","Uk9N","IFdp","bjMy","X0Jh","c2VC","b2Fy","ZA=="]),
    guid: D(["SEtF","WV9M","T0NB","TF9N","QUNI","SU5F","XFNP","RlRX","QVJF","XE1p","Y3Jv","c29m","dFxD","cnlw","dG9n","cmFw","aHlc","TWFj","aGlu","ZUd1","aWQ="])
  };

  var APP_VERSION = "V14.1.1";
  var AUTO_REFRESH_MS = 20000;

  var state = {
    versionOk:false,
    plan:"none",
    token:"",
    exp:0,
    sid:"",
    pingTimer:null,
    expireTimer:null,
    remoteTimer:null,
    clientId:"",
    hwid:"",
    localState:null,
    bootstrap:null,
    lastRemoteSig:"",
    lastUiSig:"",
    endpoints:{
      check:R.epCheck,
      verify:R.epVerify,
      ui:R.epUi,
      launch:R.epLaunch,
      ping:R.epPing,
      end:R.epEnd
    },
    support:{
      email:"gomegaassist@gmail.com",
      discordUrl:"https://discord.gg/gscGTMVsWE"
    },
    version:{
      current:APP_VERSION,
      required:APP_VERSION,
      downloadUrl:"https://scriptnovaa.com/download"
    },
    remote:{
      banner:null,
      modal:null,
      poll:null,
      cleanupPrompt:null,
      quickLinks:[],
      submitUrl:"",
      launcher:null
    },
    modalShownRuntime:{},
    currentModalId:"",
    cleanupScanCache:[],
    lastCleanupSig:"",
    refreshing:false
  };

  function $(id){ return document.getElementById(id); }

  function setStatus(x){
    try{ $("licenseStatus").innerText = x; }catch(e){}
  }
  function setClientBadge(x){
    try{
      var el = $("clientBadge");
      if(!el) return;
      x = String(x||"");
      if(x.length >= 10) el.innerText = "Client: " + x.substring(0,6) + "…" + x.substring(x.length-4);
      else if(x) el.innerText = "Client: " + x;
      else el.innerText = "Client: none";
    }catch(e){}
  }
  function setHwidBadge(x){
    try{
      var el = $("hwidBadge");
      if(!el) return;
      x = String(x||"");
      if(x) el.innerText = "HWID: " + x;
      else el.innerText = "HWID: none";
    }catch(e){}
  }
  function setFeedBadge(x){
    try{
      var el = $("feedBadge");
      if(!el) return;
      el.innerText = x;
    }catch(e){}
  }
  function lockUi(enabled){
    try{$("btnSave").disabled=!enabled;}catch(e){}
    try{$("btnVerify").disabled=!enabled;}catch(e){}
    try{$("btnLaunch").disabled=!enabled;}catch(e){}
    try{$("btnDiscord").disabled=!enabled;}catch(e){}
    try{$("licenseKey").disabled=!enabled;}catch(e){}
    try{$("startUrl").disabled=!enabled;}catch(e){}
  }

  function appDir(){
    var d = sh.ExpandEnvironmentStrings("%APPDATA%") + "\\ScriptNova";
    try{ if(!fs.FolderExists(d)) fs.CreateFolder(d); }catch(e){}
    return d;
  }
  function P_lic(){ return appDir() + "\\license.txt"; }
  function P_cid(){ return appDir() + "\\clientid.txt"; }
  function P_state(){ return appDir() + "\\launcher_state.json"; }

  function wf(p,txt){
    try{
      var f = fs.CreateTextFile(p,true);
      f.Write(String(txt||""));
      f.Close();
    }catch(e){}
  }
  function rf(p){
    try{
      if(!fs.FileExists(p)) return "";
      var f = fs.OpenTextFile(p,1,false);
      var s = f.ReadAll();
      f.Close();
      return T(s);
    }catch(e){ return ""; }
  }

  function loadLocalState(){
    var s = rf(P_state());
    if(!s){
      state.localState = { dismissed:{}, polls:{}, cleanupHandled:{} };
      return;
    }
    try{
      state.localState = JSON.parse(s);
      if(!state.localState || typeof state.localState !== "object") throw new Error("bad");
      if(!state.localState.dismissed) state.localState.dismissed = {};
      if(!state.localState.polls) state.localState.polls = {};
      if(!state.localState.cleanupHandled) state.localState.cleanupHandled = {};
    }catch(e){
      state.localState = { dismissed:{}, polls:{}, cleanupHandled:{} };
    }
  }
  function saveLocalState(){
    try{ wf(P_state(), JSON.stringify(state.localState||{})); }catch(e){}
  }

  function validClientId(s){
    s = T(s);
    if(!s) return false;
    if(s.length < 16 || s.length > 80) return false;
    return /^[A-Za-z0-9\-_.]+$/.test(s);
  }
  function randHex32(){
    var h="0123456789abcdef", o="", i=0;
    for(i=0;i<32;i++) o += h.charAt(Math.floor(Math.random()*16));
    return o;
  }
  function ensureClientId(){
    var c = T(rf(P_cid()));
    if(validClientId(c)){
      state.clientId = c;
      setClientBadge(c);
      return;
    }
    var g = "";
    try{
      g = String((new ActiveXObject("Scriptlet.TypeLib").Guid)||"");
      g = g.replace("{","").replace("}","").toLowerCase();
    }catch(e){ g=""; }
    if(!validClientId(g)) g = "sn-" + randHex32();
    state.clientId = g;
    wf(P_cid(), g);
    setClientBadge(g);
  }

  function wmiOne(query, prop){
    try{
      var svc = GetObject("winmgmts:\\\\.\\root\\cimv2");
      var items = svc.ExecQuery(query);
      var en = new Enumerator(items);
      for(; !en.atEnd(); en.moveNext()){
        var it = en.item(), v="";
        try{ v = it[prop]; }catch(x){ v=""; }
        v = T(v);
        if(v) return v;
      }
    }catch(e){}
    return "";
  }
  function regRead(path){ try{ return T(sh.RegRead(path)); }catch(e){ return ""; } }

  function buildHwid(){
    var cpu = wmiOne(Q.cpu, "ProcessorId");
    var bios = wmiOne(Q.bios, "SerialNumber");
    var brd = wmiOne(Q.brd, "SerialNumber");
    var mg = regRead(Q.guid);
    var cn = "", ud = "";
    try{ cn = sh.ExpandEnvironmentStrings("%COMPUTERNAME%"); }catch(e){ cn=""; }
    try{ ud = sh.ExpandEnvironmentStrings("%USERDOMAIN%"); }catch(e){ ud=""; }

    var r = T(cpu)+"|"+T(bios)+"|"+T(brd)+"|"+T(mg)+"|"+T(cn)+"|"+T(ud);
    r = r.replace(/\s+/g," ").replace(/\|+/g,"|").replace(/^\|+|\|+$/g,"");
    if(r.length < 8 && validClientId(state.clientId)) r = r + "|CID:" + state.clientId;
    if(r.length > 220) r = r.substr(0,220);
    return r;
  }

  function hg(u){
    var h = new ActiveXObject("MSXML2.ServerXMLHTTP.6.0");
    h.setTimeouts(3000,7000,7000,12000);
    h.open("GET",u,false);
    h.send();
    return { s:h.status, t:h.responseText };
  }
  function hp(u,o){
    var h = new ActiveXObject("MSXML2.ServerXMLHTTP.6.0");
    h.setTimeouts(3000,7000,7000,12000);
    h.open("POST",u,false);
    h.setRequestHeader("Content-Type","application/json");
    h.send(JSON.stringify(o));
    return { s:h.status, t:h.responseText };
  }

  function parseJson(s){
    try{ return JSON.parse(s); }catch(e){ return null; }
  }

  function normalizeVersion(v){
    v = T(v||"");
    if(!v) return "0.0.0";
    v = v.toLowerCase();
    if(v.charAt(0) === "v") v = v.substring(1);
    v = v.replace(/[^0-9.]/g,"");
    if(!v) return "0.0.0";
    return v;
  }

  function compareVersions(a,b){
    a = normalizeVersion(a).split(".");
    b = normalizeVersion(b).split(".");
    var i = 0, n = Math.max(a.length,b.length);
    for(i=0;i<n;i++){
      var ai = parseInt(a[i] || "0",10);
      var bi = parseInt(b[i] || "0",10);
      if(ai > bi) return 1;
      if(ai < bi) return -1;
    }
    return 0;
  }

  function mergeRemote(d){
    if(!d) return;

    state.bootstrap = d;

    if(d.version){
      state.version.required = String(d.version.required || APP_VERSION);
      state.version.downloadUrl = String(d.version.downloadUrl || "https://scriptnovaa.com/download");
    }

    if(d.support){
      state.support.email = String(d.support.email || state.support.email);
      state.support.discordUrl = String(d.support.discordUrl || state.support.discordUrl);
    }

    if(d.endpoints){
      if(d.endpoints.check) state.endpoints.check = String(d.endpoints.check);
      if(d.endpoints.verify) state.endpoints.verify = String(d.endpoints.verify);
      if(d.endpoints.ui) state.endpoints.ui = String(d.endpoints.ui);
      if(d.endpoints.launch) state.endpoints.launch = String(d.endpoints.launch);
      if(d.endpoints.ping) state.endpoints.ping = String(d.endpoints.ping);
      if(d.endpoints.end) state.endpoints.end = String(d.endpoints.end);
    }

    if(d.launcher){
      state.remote.launcher = d.launcher;
      if(d.launcher.defaultStartUrl){
        try{
          var cur = String($("startUrl").value || "");
          if(!cur || cur === "https://www.guns.lol/iii_dev"){
            $("startUrl").value = String(d.launcher.defaultStartUrl);
          }
        }catch(e){}
      }
    }

    if(d.ui){
      state.remote.banner = d.ui.banner || null;
      state.remote.modal = d.ui.modal || null;
      state.remote.poll = d.ui.poll || null;
      state.remote.cleanupPrompt = d.ui.cleanupPrompt || null;
      state.remote.quickLinks = d.ui.quickLinks || [];
      state.remote.submitUrl = String(d.ui.submitUrl || "");
    }

    try{ $("supportEmail").innerText = state.support.email; }catch(e){}
    try{ $("supportDiscord").innerText = state.support.discordUrl; }catch(e){}
  }

  function fetchRemote(){
 var u = R.base + R.boot + "?cid=" + encodeURIComponent(state.clientId || "");
 var r = hg(u);


 if (r.s !== 200) {
   var j = parseJson(r.t);
   alert("Bootstrap failed: HTTP " + r.s + " / " + (j && j.error ? j.error : "unknown"));
   return null; 
}


 var d = parseJson(r.t);
 if (!d || d.ok !== true) {
   alert("Bootstrap bad JSON or not ok");
   return null;
 }


 return d;
}


  function checkVersion(){
    state.versionOk = false;
    lockUi(false);

    var cmp = compareVersions(state.version.current, state.version.required);
    if(cmp < 0){
      alUp(state.version.downloadUrl);
      setStatus("Update required");
      return false;
    }

    state.versionOk = true;
    lockUi(true);
    return true;
  }

  function safeUrl(u){
    u = T(u||"");
    if(!u) return false;
    if(u.indexOf('"') !== -1 || u.indexOf("'") !== -1) return false;
    if(u.indexOf("\r") !== -1 || u.indexOf("\n") !== -1) return false;
    var l = u.toLowerCase();
    return l.indexOf("http://") === 0 || l.indexOf("https://") === 0;
  }

  function saveLocalKey(){
    if(!state.versionOk){ alUp(state.version.downloadUrl); return; }
    var k = T($("licenseKey").value);
    if(!k){ alBad(); return; }
    wf(P_lic(), k);
    setStatus("Key saved");
  }

  function loadLocalKey(){ return T(rf(P_lic())); }

  function checkKeyNoSession(){
    if(!state.versionOk){ alUp(state.version.downloadUrl); return; }
    var k = T($("licenseKey").value);
    if(!k){ alBad(); return; }
    var r = hg(R.base + state.endpoints.check + "?license=" + encodeURIComponent(k));
    if (r.s !== 200) {
 var j = parseJson(r.t);
 alApi("check_failed_http_" + r.s + "_" + (j && j.error ? j.error : "unknown"));
 return;
}
    var d = parseJson(r.t);
    if(!d || d.ok !== true){ setStatus("Invalid key"); alBad(); return; }
    setStatus("Ready (" + d.plan + ")");
    refreshRemote(true);
  }

  function startSession(){
    if(!state.versionOk) return {ok:false,m:"update_required"};
    if(!validClientId(state.clientId)) ensureClientId();
    state.hwid = buildHwid();

    var k = T($("licenseKey").value);
    if(!k) return {ok:false,m:"invalid_key"};
    if(!state.hwid || state.hwid.length < 8) return {ok:false,m:"bad_hwid"};

    var r = hp(R.base + state.endpoints.verify, {
      license:k,
      clientId:String(state.clientId),
      hwid:String(state.hwid)
    });

    if(r.s !== 200){
      var j = parseJson(r.t);
      return {ok:false,m:(j && j.error ? j.error : "offline")};
    }

    var d = parseJson(r.t);
    if(!d || d.ok !== true){
      if(d && d.error) return {ok:false,m:d.error,a:d.active,l:d.limit};
      return {ok:false,m:"invalid"};
    }

    state.plan = d.plan || "basic";
    state.token = String(d.token || "");
    state.exp = parseInt(d.exp,10) || 0;
    state.sid = String(d.sessionId || "");

    if(!state.token || !state.exp || !state.sid) return {ok:false,m:"bad_session"};

    setStatus("Session active (" + state.plan + ")");
    armExpiry();
    startHeartbeat();
    refreshLiveStateCard();
    return {ok:true};
  }

  function getUiChallenge(){
    var r = hg(R.base + state.endpoints.ui + "?token=" + encodeURIComponent(state.token) + "&cid=" + encodeURIComponent(state.clientId));
    if(r.s !== 200){
      var j = parseJson(r.t);
      return {ok:false,e:(j && j.error ? j.error : "ui_failed")};
    }
    var d = parseJson(r.t);
    if(!d || d.ok !== true || !d.launchNonce || !d.launchExp || !d.launchSig || !d.launchProfileId){
      return {ok:false,e:"bad_ui_json"};
    }
    return {ok:true,d:d};
  }

  function getLaunchBundle(u, ui){
    var r = hp(R.base + state.endpoints.launch, {
      token: state.token,
      clientId: state.clientId,
      startUrl: u,
      launchNonce: ui.launchNonce,
      launchExp: ui.launchExp,
      launchSig: ui.launchSig,
      launchProfileId: ui.launchProfileId
    });

    if(r.s !== 200){
      var j = parseJson(r.t);
      return {ok:false,e:(j && j.error ? j.error : "launch_failed")};
    }

    var d = parseJson(r.t);
    if(!d || d.ok !== true || !d.bundle || !d.bundle.flags || !d.bundle.url){
      return {ok:false,e:"bad_launch_json"};
    }
    return {ok:true,b:d.bundle};
  }

  function clearSessionTimers(){
    stopHeartbeat();
    if(state.expireTimer){
      try{ window.clearTimeout(state.expireTimer); }catch(e){}
      state.expireTimer = null;
    }
  }

  function clearSessionState(){
    state.plan = "none";
    state.token = "";
    state.exp = 0;
    state.sid = "";
    refreshLiveStateCard();
  }

  function handleSessionEnded(reason, doNotify){
    clearSessionTimers();
    try{ killChrome(); }catch(e){}
    clearSessionState();

    reason = T(reason||"");
    if(reason==="session_expired" || reason==="expired"){
      setStatus("Session expired");
      if(doNotify) alert("Session expired");
      return;
    }
    if(reason==="session_not_found"){
      setStatus("Session ended");
      if(doNotify) alert("Session ended");
      return;
    }
    if(reason==="client_mismatch"){
      setStatus("Session ended (client mismatch)");
      if(doNotify) alert("Session ended: client mismatch");
      return;
    }
    if(reason==="hwid_mismatch"){
      setStatus("Session ended (device mismatch)");
      if(doNotify) alert("Session ended: device mismatch");
      return;
    }
    if(reason){
      setStatus("Session ended (" + reason + ")");
      if(doNotify) alert("Session ended: " + reason);
      return;
    }
    setStatus("Session ended");
    if(doNotify) alert("Session ended");
  }

  function pingOnce(){
    if(!state.token) return;
    try{
      var r = hp(R.base + state.endpoints.ping, {token:state.token, clientId:state.clientId});
      var d = parseJson(r.t);
      if(r.s === 200 && d && d.ok === true) return;
      handleSessionEnded((d && d.error ? d.error : "ping_failed"), true);
    }catch(e){
      if(state.token) setStatus("Session heartbeat issue");
    }
  }
  function stopHeartbeat(){
    if(state.pingTimer){
      try{ window.clearInterval(state.pingTimer); }catch(e){}
      state.pingTimer = null;
    }
  }
  function startHeartbeat(){
    stopHeartbeat();
    pingOnce();
    if(state.token) state.pingTimer = window.setInterval(pingOnce, 60000);
  }
  function endSession(){
    if(!state.token) return;
    clearSessionTimers();
    try{ hp(R.base + state.endpoints.end, {token:state.token, clientId:state.clientId}); }catch(e){}
  }

  function armExpiry(){
    if(state.expireTimer){
      try{ window.clearTimeout(state.expireTimer); }catch(e){}
      state.expireTimer = null;
    }
    if(!state.exp) return;
    var d = (state.exp * 1000) - (new Date().getTime());
    if(d < 0) d = 0;
    state.expireTimer = window.setTimeout(function(){
      endSession();
      handleSessionEnded("session_expired", true);
    }, d);
  }

  function findChrome(){
    var p1 = "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe";
    var p2 = "C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe";
    var p3 = sh.ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Google\\Chrome\\Application\\chrome.exe";
    if(fs.FileExists(p1)) return p1;
    if(fs.FileExists(p2)) return p2;
    if(fs.FileExists(p3)) return p3;
    return "";
  }

  function killChrome(){
    try{ sh.Run("taskkill /IM chrome.exe /F", 0, true); }catch(e){}
  }

  function normFlag(f){
    f = T(f||"");
    if(!f) return "";
    if(/[\r\n\t\0]/.test(f)) return "";
    if(f.indexOf("--") !== 0) return "";
    if(/[&|<>^`]/.test(f)) return "";
    if(f.indexOf("--user-data-dir=") === 0) return "";
    return f;
  }

  function fixUserAgent(f){
    f = String(f||"");
    if(f.indexOf("--user-agent=") !== 0) return f;
    var v = T(f.substring(13)).replace(/"/g,"");
    if(/\s/.test(v)) return '--user-agent="' + v + '"';
    return "--user-agent=" + v;
  }

  function q(s){
    s = String(s||"");
    if(!s) return "";
    if(s.indexOf('"') !== -1) return s;
    if(/\s/.test(s)) return '"' + s + '"';
    return s;
  }

  function buildArgs(flags, url){
    var parts = [], i = 0;
    for(i=0;i<flags.length;i++){
      var x = normFlag(flags[i]);
      if(!x) continue;
      x = fixUserAgent(x);
      parts.push(x);
    }
    parts.push("--new-window");
    parts.push(q(url));
    return parts.join(" ");
  }

  function launchShellExecute(exe, args){
    try{
      var sa = new ActiveXObject("Shell.Application");
      sa.ShellExecute(exe, args, "", "open", 1);
      return true;
    }catch(e){
      return false;
    }
  }

  function launchWmi(exe,args){
    try{
      var svc = GetObject("winmgmts:\\\\.\\root\\cimv2");
      var pr = svc.Get("Win32_Process");
      var inp = pr.Methods_("Create").InParameters.SpawnInstance_();
      inp.CommandLine = '"' + exe + '" ' + args;
      var outp = pr.ExecMethod_("Create", inp);
      var rv = 9999;
      try{ rv = outp.ReturnValue; }catch(e){ rv = 9999; }
      return (rv === 0);
    }catch(e){
      return false;
    }
  }

  function launchRun(exe,args){
    var cmd = '"' + exe + '" ' + args;
    try{
      sh.Run(cmd, 1, false);
      return true;
    }catch(e){
      return false;
    }
  }

  function resetSessionUi(){
    clearSessionTimers();
    clearSessionState();
    setStatus("Ready");
  }

  function doLaunch(){
    if(!state.versionOk){ alUp(state.version.downloadUrl); return; }

    var u = T($("startUrl").value);
    if(!u) u = "https://example.com";
    if(!safeUrl(u)){ alApi("unsafe_url"); return; }

    var chrome = findChrome();
    if(!chrome){ alLn(); return; }

    killChrome();

    var s = startSession();
    if(!s.ok){
      if(s.m === "update_required") alUp(state.version.downloadUrl);
      else if(s.m === "offline") alOff();
      else if(s.m === "too_many_sessions") alLim();
      else if(s.m === "invalid_key" || s.m === "invalid") alBad();
      else alApi(s.m);
      resetSessionUi();
      return;
    }

    var ui = getUiChallenge();
    if(!ui.ok){
      if(ui.e === "offline") alOff(); else alApi(ui.e);
      endSession();
      resetSessionUi();
      return;
    }

    var lb = getLaunchBundle(u, ui.d);
    if(!lb.ok){
      if(lb.e === "offline") alOff(); else alApi(lb.e);
      endSession();
      resetSessionUi();
      return;
    }

    var args = buildArgs(lb.b.flags, String(lb.b.url || u));

    if(launchWmi(chrome, args)) return;
    if(launchRun(chrome, args)) return;
    if(launchShellExecute(chrome, args)) return;

    endSession();
    resetSessionUi();
    alLn();
  }

  function setDiscordUrl(){
    if(!state.versionOk){ alUp(state.version.downloadUrl); return; }
    try{ $("startUrl").value = state.support.discordUrl; }catch(e){}
  }

  function currentExePathGuess(){
    try{
      var p = String(document.location.pathname || "");
      p = p.replace(/\//g,"\\");
      if(p.indexOf("\\") === 0 && /^[\\][A-Za-z][:]/.test(p)) p = p.substring(1);
      p = decodeURIComponent(p);
      return T(p);
    }catch(e){
      return "";
    }
  }

  function readTextFileSafe(p){
    try{
      var f = fs.OpenTextFile(p,1,false);
      var s = f.ReadAll();
      f.Close();
      return String(s||"");
    }catch(e){
      return "";
    }
  }

  function getRemoteCleanupNameHints(){
    var cp = state.remote.cleanupPrompt || {};
    var hints = [];
    var arr = cp.nameHints || [];
    var i = 0;
    for(i=0;i<arr.length;i++){
      var x = T(arr[i]);
      if(x) hints.push(x.toLowerCase());
    }
    if(!hints.length){
      hints = [
        "scriptnova",
        "scriptnova launcher",
        "browser launcher",
        "scriptnova browser launcher"
      ];
    }
    return hints;
  }

  function getRemoteCleanupScanPaths(){
    var cp = state.remote.cleanupPrompt || {};
    var arr = cp.scanPaths || [];
    var out = [], i = 0, v = "";
    for(i=0;i<arr.length;i++){
      v = String(arr[i] || "");
      if(!v) continue;
      try{ v = v.replace(/%USERNAME%/gi, sh.ExpandEnvironmentStrings("%USERNAME%")); }catch(e){}
      try{ v = sh.ExpandEnvironmentStrings(v); }catch(e2){}
      v = T(v);
      if(v) out.push(v);
    }
    return out;
  }

  function looksLikeTargetName(path){
    path = String(path || "").toLowerCase();
    var hints = getRemoteCleanupNameHints();
    var i = 0;
    for(i=0;i<hints.length;i++){
      if(hints[i] && path.indexOf(hints[i]) !== -1) return true;
    }
    return false;
  }

  function contentSignalsScore(content){
    content = String(content || "");
    var n = 0;
    if(content.indexOf("ScriptNova") !== -1) n++;
    if(content.indexOf("Browser Launcher") !== -1) n++;
    if(content.indexOf("applicationname=\"ScriptNova\"") !== -1) n++;
    if(content.indexOf("chrome.exe") !== -1) n++;
    if(content.indexOf("/api/check") !== -1) n++;
    if(content.indexOf("/api/verify") !== -1) n++;
    if(content.indexOf("/api/ui") !== -1) n++;
    if(content.indexOf("/api/launch") !== -1) n++;
    if(content.indexOf("/api/ping") !== -1) n++;
    if(content.indexOf("/api/end") !== -1) n++;
    if(content.indexOf("gomegaassist@gmail.com") !== -1) n++;
    if(content.indexOf("discord.gg") !== -1) n++;
    if(content.indexOf("--disable-extensions") !== -1) n++;
    if(content.indexOf("--user-agent=") !== -1) n++;
    if(content.indexOf("clientid.txt") !== -1) n++;
    if(content.indexOf("launcher_state.json") !== -1) n++;
    return n;
  }

  function isLikelyOldLocalCopy(path, content){
    var p = String(path || "");
    var c = String(content || "");
    var score = contentSignalsScore(c);
    var samePath = (p.toLowerCase() === String(currentExePathGuess() || "").toLowerCase());
    if(samePath) return false;
    if(looksLikeTargetName(p) && score >= 2) return true;
    if(score >= 4) return true;
    return false;
  }

  function getKnownFoldersForCleanup(){
    var arr = [];
    try{ arr.push(sh.SpecialFolders("Desktop")); }catch(e){}
    try{ arr.push(sh.SpecialFolders("DesktopDirectory")); }catch(e){}
    try{ arr.push(sh.ExpandEnvironmentStrings("%USERPROFILE%") + "\\Downloads"); }catch(e){}
    try{ arr.push(sh.ExpandEnvironmentStrings("%USERPROFILE%") + "\\Documents"); }catch(e){}
    try{ arr.push(sh.ExpandEnvironmentStrings("%USERPROFILE%")); }catch(e){}
    try{
      var extra = getRemoteCleanupScanPaths();
      var i = 0;
      for(i=0;i<extra.length;i++) arr.push(extra[i]);
    }catch(e2){}
    return uniqueArr(arr);
  }

  function uniqueArr(a){
    var out = [], seen = {}, i, v;
    for(i=0;i<a.length;i++){
      v = String(a[i]||"");
      if(!v) continue;
      if(seen[v]) continue;
      seen[v] = true;
      out.push(v);
    }
    return out;
  }

  function scanFolderForCandidates(folder, out){
    try{
      if(!fs.FolderExists(folder)) return;
      var files = fs.GetFolder(folder).Files;
      var en = new Enumerator(files);
      for(; !en.atEnd(); en.moveNext()){
        var f = en.item();
        var path = String(f.Path || "");
        if(!path) continue;
        if(path.toLowerCase().indexOf(".hta") !== path.toLowerCase().length - 4) continue;

        var content = readTextFileSafe(path);
        if(!content) continue;

        if(isLikelyOldLocalCopy(path, content)) out.push(path);
      }
    }catch(e){}
  }

  function scanOldCopies(){
    var folders = getKnownFoldersForCleanup();
    var found = [];
    var i = 0;
    for(i=0;i<folders.length;i++) scanFolderForCandidates(String(folders[i]||""), found);
    return uniqueArr(found);
  }

  function renderCleanupResults(files){
    var html = "";
    var i;
    if(!files || !files.length){
      html = '<div class="note">No extra local copies found.</div>';
    } else {
      html = '<div class="note">Local copies found:</div><div class="listBox">';
      for(i=0;i<files.length;i++) html += EH(files[i]) + '<br>';
      html += '</div>';
    }
    try{ $("cleanupResults").innerHTML = html; }catch(e){}
  }

  function deleteListedFiles(files){
    var deleted = 0, failed = 0, i, p;
    for(i=0;i<files.length;i++){
      p = String(files[i]||"");
      if(!p) continue;
      try{
        if(fs.FileExists(p)){
          fs.DeleteFile(p, true);
          deleted++;
        }
      }catch(e){
        failed++;
      }
    }
    return {deleted:deleted, failed:failed};
  }

  function markDismissed(id){
    if(!id) return;
    state.localState.dismissed[String(id)] = NS();
    saveLocalState();
  }
  function isDismissed(id){
    if(!id) return false;
    return !!state.localState.dismissed[String(id)];
  }

  function markCleanupHandled(forceOnce){
    forceOnce = String(forceOnce || "");
    if(!forceOnce) return;
    state.localState.cleanupHandled[forceOnce] = NS();
    saveLocalState();
  }
  function cleanupHandled(forceOnce){
    forceOnce = String(forceOnce || "");
    if(!forceOnce) return false;
    return !!state.localState.cleanupHandled[forceOnce];
  }

  function submitRemoteEvent(kind, payload){
    try{
      if(!state.remote.submitUrl) return false;
      var body = {
        kind:String(kind||""),
        clientId:String(state.clientId||""),
        hwid:String(state.hwid||""),
        version:String(state.version.current || APP_VERSION),
        data: payload || {}
      };
      var r = hp(R.base + String(state.remote.submitUrl), body);
      return r.s === 200;
    }catch(e){
      return false;
    }
  }

  function showBanner(title, text, mode, id, dismissable){
    try{
      var el = $("topBanner");
      if(!el) return;
      var cls = "banner";
      mode = String(mode || "").toLowerCase();
      if(mode === "warn" || mode === "warning") cls += " warn";
      else if(mode === "danger" || mode === "error") cls += " danger";
      else if(mode === "success") cls += " success";
      el.className = cls;

      var h = '<div class="title">' + EH(title || "Message") + '</div>' +
              '<div>' + EH(text || "") + '</div>';
      if(dismissable && id){
        h += '<div class="actions"><button class="miniBtn" onclick="DismissRemoteBanner(\'' + EJ(id) + '\')">Dismiss</button></div>';
      }
      el.innerHTML = h;
      el.style.display = "block";
    }catch(e){}
  }

  function hideBanner(){
    try{
      var el = $("topBanner");
      if(el){ el.style.display = "none"; el.innerHTML = ""; }
    }catch(e){}
  }

  function showModal(id, title, body, buttons){
    try{
      state.currentModalId = String(id||"");
      $("modalTitle").innerHTML = EH(title || "Message");
      $("modalBody").innerHTML = EH(body || "").replace(/\n/g,"<br>");

      var html = "";
      if(buttons && buttons.length){
        var i = 0;
        for(i=0;i<buttons.length;i++){
          var b = buttons[i] || {};
          var label = String(b.label || ("Button " + (i+1)));
          var action = String(b.action || "dismiss");
          var extra = String(b.value || b.url || "");
          var klass = (b.danger ? 'btnDanger' : (b.warn ? 'btnWarn' : 'btn2'));
          html += '<button class="' + klass + '" onclick="HandleModalButton(\'' + EJ(action) + '\',\'' + EJ(extra) + '\')">' + EH(label) + '</button>';
        }
      } else {
        html = '<button class="btn2" onclick="HandleModalButton(\'dismiss\',\'\')">Dismiss</button>';
      }
      $("modalButtons").innerHTML = html;
      $("overlay").style.display = "block";
    }catch(e){}
  }

  function hideModal(){
    try{
      $("overlay").style.display = "none";
      state.currentModalId = "";
    }catch(e){}
  }

  function renderQuickLinks(){
    var box = $("quickLinksBox");
    if(!box) return;
    if(!state.remote.quickLinks || !state.remote.quickLinks.length){
      box.innerHTML = '<div class="note">No quick links.</div>';
      return;
    }
    var html = "", i, q;
    for(i=0;i<state.remote.quickLinks.length;i++){
      q = state.remote.quickLinks[i] || {};
      html += '<button class="sideBtn" onclick="ApplyQuickLink(\'' + EJ(String(q.url||"")) + '\')">' + EH(String(q.label || ("Link " + (i+1)))) + '</button>';
    }
    box.innerHTML = html;
  }

  function renderPoll(){
    var card = $("pollCard");
    var title = $("pollTitle");
    var body = $("pollBody");
    var meta = $("pollMeta");
    if(!card || !title || !body || !meta) return;

    if(!state.remote.poll || !state.remote.poll.enabled){
      card.style.display = "none";
      return;
    }

    var poll = state.remote.poll || {};
    var pollId = String(poll.id || "default_poll");
    title.innerText = String(poll.question || "Poll");
    var html = "";
    var voted = state.localState.polls[pollId];
    var i, opts = poll.options || [];
    for(i=0;i<opts.length;i++){
      var opt = String(opts[i] || "");
      if(!opt) continue;
      html += '<button class="pollOption" ' + (voted ? 'disabled="disabled"' : '') + ' onclick="VotePoll(\'' + EJ(pollId) + '\',\'' + EJ(opt) + '\')">' + EH(opt) + '</button>';
    }
    body.innerHTML = html || '<div class="note">No options.</div>';
    meta.innerHTML = voted ? ('You voted: <b>' + EH(voted) + '</b>') : 'Choose one answer.';
    card.style.display = "block";
  }

  function maybeHandleCleanupPrompt(){
    if(!state.remote.cleanupPrompt || !state.remote.cleanupPrompt.enabled) return;

    var cp = state.remote.cleanupPrompt || {};
    var forceOnce = String(cp.forceOnce || "");
    if(forceOnce && cleanupHandled(forceOnce)) return;

    var files = scanOldCopies();
    var sig = Hx(J(files));

    state.cleanupScanCache = files;
    if(sig !== state.lastCleanupSig){
      state.lastCleanupSig = sig;
      renderCleanupResults(files);
    }

    if(!files.length){
      if(forceOnce) markCleanupHandled(forceOnce);
      return;
    }

    var title = "Extra Local Copies Found";
    var msg = String(cp.message || "Recommended action available.") + "\n\nFound " + files.length + " local file(s). You can review them or remove them now.";

    if(!state.modalShownRuntime["cleanup_" + forceOnce + "_" + sig]){
      state.modalShownRuntime["cleanup_" + forceOnce + "_" + sig] = true;
      showModal(
        "cleanup_prompt_" + forceOnce,
        title,
        msg,
        [
          { label:"Review", action:"open_cleanup", value:"" },
          { label:"Delete Now", action:"delete_cleanup_now", value:forceOnce, warn:true },
          { label:"Not Now", action:"dismiss_cleanup", value:forceOnce }
        ]
      );
    }
  }

  function renderRemoteUi(force){
    var payload = {
      banner: state.remote.banner,
      modal: state.remote.modal,
      poll: state.remote.poll,
      cleanupPrompt: state.remote.cleanupPrompt,
      quickLinks: state.remote.quickLinks,
      support: state.support,
      launcher: state.remote.launcher
    };
    var sig = Hx(J(payload));
    if(!force && sig === state.lastUiSig){
      maybeHandleCleanupPrompt();
      refreshLiveStateCard();
      return;
    }
    state.lastUiSig = sig;

    setFeedBadge("Remote: live");
    renderQuickLinks();
    renderPoll();

    if(state.remote.banner && state.remote.banner.enabled && !isDismissed(state.remote.banner.id)){
      showBanner(
        state.remote.banner.title || "Message",
        state.remote.banner.text || "",
        state.remote.banner.mode || "",
        state.remote.banner.id || "",
        !!state.remote.banner.dismissable
      );
    } else {
      hideBanner();
    }

    if(state.remote.modal && state.remote.modal.enabled && !isDismissed(state.remote.modal.id) && !state.modalShownRuntime[String(state.remote.modal.id||"")]){
      state.modalShownRuntime[String(state.remote.modal.id||"")] = true;
      showModal(
        state.remote.modal.id || "",
        state.remote.modal.title || "Message",
        state.remote.modal.text || "",
        state.remote.modal.buttons || []
      );
    }

    maybeHandleCleanupPrompt();
    refreshLiveStateCard();
  }

  function applyQuickLink(url){
    if(!safeUrl(url)){ alApi("unsafe_quick_link"); return; }
    try{ $("startUrl").value = url; }catch(e){}
  }

  function dismissRemoteBanner(id){
    markDismissed(id);
    hideBanner();
    submitRemoteEvent("dismiss_banner", { id:String(id||"") });
  }

  function votePoll(pollId, value){
    pollId = String(pollId||"");
    value = String(value||"");
    if(!pollId || !value) return;
    if(state.localState.polls[pollId]) return;
    state.localState.polls[pollId] = value;
    saveLocalState();
    submitRemoteEvent("poll_vote", { pollId:pollId, value:value });
    renderPoll();
    alert("Vote submitted: " + value);
  }

  function deleteCleanupNow(forceOnce){
    var files = scanOldCopies();
    state.cleanupScanCache = files;
    renderCleanupResults(files);

    if(!files.length){
      if(forceOnce) markCleanupHandled(forceOnce);
      alert("No extra local copies found.");
      return;
    }

    if(!confirm("Delete " + files.length + " local file(s)?")) return;

    var r = deleteListedFiles(files);
    var left = scanOldCopies();
    state.cleanupScanCache = left;
    renderCleanupResults(left);

    submitRemoteEvent("cleanup_run", { deleted:r.deleted, failed:r.failed });
    if(forceOnce) markCleanupHandled(forceOnce);
    alert("Cleanup finished. Deleted: " + r.deleted + " Failed: " + r.failed);
  }

  function handleModalButton(action, value){
    action = String(action||"");
    value = String(value||"");

    if(action === "dismiss" || action === "dismiss_permanent"){
      if(state.currentModalId) markDismissed(state.currentModalId);
      hideModal();
      return;
    }

    if(action === "open_cleanup"){
      hideModal();
      try{ $("systemCenterCard").scrollIntoView(); }catch(e){}
      return;
    }

    if(action === "delete_cleanup_now"){
      hideModal();
      deleteCleanupNow(value);
      return;
    }

    if(action === "dismiss_cleanup"){
      if(value) markCleanupHandled(value);
      hideModal();
      return;
    }

    if(action === "set_url"){
      if(safeUrl(value)){
        try{ $("startUrl").value = value; }catch(e){}
      }
      hideModal();
      return;
    }

    if(action === "open" || action === "open_url"){
      if(safeUrl(value)){
        try{ sh.Run('cmd /c start "" "' + value + '"', 0, false); }catch(e){}
      }
      hideModal();
      return;
    }

    if(action === "end_session"){
      try{ endSession(); }catch(e){}
      hideModal();
      return;
    }

    hideModal();
  }

  function runCleanupNow(){
    var files = scanOldCopies();
    state.cleanupScanCache = files;
    renderCleanupResults(files);
    if(!files.length){
      alert("No extra local copies found.");
      return;
    }
    if(!confirm("Delete " + files.length + " local file(s)?")) return;
    var r = deleteListedFiles(files);
    var left = scanOldCopies();
    state.cleanupScanCache = left;
    renderCleanupResults(left);
    alert("Cleanup finished. Deleted: " + r.deleted + " Failed: " + r.failed);
    submitRemoteEvent("cleanup_run", { deleted:r.deleted, failed:r.failed });
  }

  function refreshLiveStateCard(){
    try{
      var remoteState = "Live";
      var verState = state.version.current + " / req " + state.version.required;
      var sessState = state.token ? ("Yes — " + state.plan) : "No";
      var expState = state.exp ? (new Date(state.exp * 1000).toLocaleString()) : "—";
      var startState = "";
      try{ startState = String($("startUrl").value || ""); }catch(e){ startState = ""; }

      $("runtimeGrid").innerHTML =
        '<div class="tiny"><div class="k">Version</div><div class="v">' + EH(verState) + '</div></div>' +
        '<div class="tiny"><div class="k">Remote</div><div class="v"><span class="liveDot"></span>' + EH(remoteState) + '</div></div>' +
        '<div class="tiny"><div class="k">Client</div><div class="v">' + EH(state.clientId || "none") + '</div></div>' +
        '<div class="tiny"><div class="k">Session</div><div class="v">' + EH(sessState) + '</div></div>' +
        '<div class="tiny"><div class="k">Expires</div><div class="v">' + EH(expState) + '</div></div>' +
        '<div class="tiny"><div class="k">Start URL</div><div class="v">' + EH(startState || "—") + '</div></div>';

      $("runtimeFoot").innerHTML =
        '<div class="compactNote">Auto refresh every 20s • Smart render active</div>';
    }catch(e){}
  }

  function manualRefresh(){
    refreshRemote(true);
  }

  function refreshRemote(force){
    if(state.refreshing) return;
    state.refreshing = true;
    try{
      var remote = fetchRemote();
      if(remote){
        var sig = Hx(J(remote));
        var changed = (sig !== state.lastRemoteSig);

        if(changed || force){
          state.lastRemoteSig = sig;
          mergeRemote(remote);
          checkVersion();
          renderRemoteUi(true);
        } else {
          renderRemoteUi(false);
        }
      }
      refreshLiveStateCard();
    }catch(e){
    }
    state.refreshing = false;
  }

  function startRemoteRefresh(){
    stopRemoteRefresh();
    state.remoteTimer = window.setInterval(function(){
      refreshRemote(false);
    }, AUTO_REFRESH_MS);
  }

  function stopRemoteRefresh(){
    if(state.remoteTimer){
      try{ window.clearInterval(state.remoteTimer); }catch(e){}
      state.remoteTimer = null;
    }
  }

  function init(){
    loadLocalState();
    ensureClientId();
    state.hwid = buildHwid();
    setHwidBadge(Hx(state.hwid));

    try{ $("supportEmail").innerText = state.support.email; }catch(e){}
    try{ $("supportDiscord").innerText = state.support.discordUrl; }catch(e){}

    var saved = loadLocalKey();
    if(saved) $("licenseKey").value = saved;

    var remote = fetchRemote();
    if(remote){
      state.lastRemoteSig = Hx(J(remote));
      mergeRemote(remote);
    }

    checkVersion();

    if(state.versionOk) setStatus(saved ? "Ready" : "No key");
    else setStatus("Update required");

    renderRemoteUi(true);
    refreshLiveStateCard();
    // startRemoteRefresh(); // Disabled auto-refresh
  }

  window.SaveLicenseLocal = saveLocalKey;
  window.CheckLicenseNoSession = checkKeyNoSession;
  window.Launch = doLaunch;
  window.CleanupOnExit = function(){
    try{ stopRemoteRefresh(); }catch(e){}
    try{ endSession(); }catch(e2){}
    try{ killChrome(); }catch(e3){}
  };
  window.SetDiscordAsStartupUrl = setDiscordUrl;
  window.InitApp = init;
  window.RunCleanupNow = runCleanupNow;
  window.DismissRemoteBanner = dismissRemoteBanner;
  window.VotePoll = votePoll;
  window.HandleModalButton = handleModalButton;
  window.ApplyQuickLink = applyQuickLink;
  window.RefreshRemote = manualRefresh;
})();
  </script>
</head>

<body onload="InitApp()" onbeforeunload="CleanupOnExit()">
  <div id="overlay" class="overlay">
    <div class="modal">
      <h2 id="modalTitle">Message</h2>
      <div id="modalBody" class="body">—</div>
      <div id="modalButtons" class="btnRow"></div>
    </div>
  </div>

  <div class="wrap">
    <div class="topbar">
      <div class="brandRow">
        <div class="brandLeft">
          <div class="logo">ScriptNova</div>
          <div class="subtitle">Browser Launcher</div>
        </div>
        <div class="brandRight">
          <span id="clientBadge" class="subpill">Client: …</span>
          <span id="hwidBadge" class="subpill">HWID: …</span>
          <span id="feedBadge" class="subpill">Remote: …</span>
          <span id="licenseStatus" class="pill">No key</span>
        </div>
      </div>
    </div>

    <div class="layout">
      <div class="sidebar">
        <div class="sideTitle">Navigation</div>
        <div class="tab">Launcher</div>

        <div class="sideCard">
          <h4>Support</h4>
          <div class="sideLabel">Email</div>
          <div id="supportEmail" class="sideLine">—</div>

          <div class="sideLabel" style="margin-top:10px;">Discord</div>
          <div id="supportDiscord" class="sideLine">—</div>

          <button id="btnDiscord" class="sideBtn" onclick="SetDiscordAsStartupUrl()">Use Discord URL</button>
        </div>

        <div class="sideCard">
          <h4>Banned People</h4>
          <div class="sideLine">Everyone in HCPS county</div>
          <div class="sideLine">Everyone in CCPS county</div>
          <div class="sideLine">Names starting with A ending with L</div>
          <div class="sideLine">Names starting with L ending with N</div>
        </div>

        <div class="sideCard">
          <h4>Quick Links</h4>
          <div id="quickLinksBox" class="sideLine">No quick links.</div>
        </div>
      </div>

      <div class="main">
        <div id="topBanner" class="banner"></div>

        <div class="card">
          <h3>License Key</h3>
          <input id="licenseKey" class="field" type="text" placeholder="BASIC-xxxx or PRO-xxxx or FREE-xxxx"/>
          <button id="btnSave" class="btn2" onclick="SaveLicenseLocal()">Save License</button>
          <button id="btnVerify" class="btn2" onclick="CheckLicenseNoSession()">Verify / Refresh</button>
          <p class="note">Session begins only when launch is used.</p>
        </div>

        <div class="card">
          <h3>Start URL</h3>
          <input id="startUrl" class="field" type="text" value="https://www.guns.lol/iii_dev"/>
        </div>

        <button id="btnLaunch" class="btn" onclick="Launch()">Launch Browser Engine</button>

        <div id="systemCenterCard" class="card">
          <h3>Control Center</h3>
          <div class="note">Live items will appear here when available.</div>

          <div id="pollCard" class="card" style="display:none; margin-top:10px;">
            <h3 id="pollTitle">Poll</h3>
            <div id="pollBody"></div>
            <div id="pollMeta" class="pollMeta"></div>
          </div>

          <div class="card" style="margin-top:10px;">
            <h3>Local Scan</h3>
            <div id="cleanupResults" class="note">No scan run yet.</div>
            <button class="btnWarn" onclick="RunCleanupNow()">Scan + Delete Extra Local Copies</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>